	"configurations": [
		{
			"args": ["dev"],
			"console": "integratedTerminal",
			"env": {
				"NODE_ENV": "development"
			},
			"name": "Debug Next.js: Server",
			"port": 9229,
			"program": "${workspaceFolder}/node_modules/next/dist/bin/next",
